{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "YarpProxy": {
    "Swagger": {
      "IsCommonDocument": false,
      "CommonDocumentName": "YARP"
    },
    "Routes": {
      "finance-service-api": {
        "ClusterId": "finance-api",
        "Match": {
          "Path": "/finance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "user-service-api": {
        "ClusterId": "user-api",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "finance-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:3001/",
            "Swaggers": [
              {
                "PrefixPath": "/finance",
                "MetadataPath": "/swagger/v1/swagger.json",
                "Paths": ["/swagger/v1/swagger.json"]
              }
            ]
          }
        }
      },
      "user-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:2001/",
            "Swaggers": [
              {
                "PrefixPath": "/user",
                "MetadataPath": "/swagger/v1/swagger.json",
                "Paths": ["/swagger/v1/swagger.json"]
              }
            ]
          }
        }
      }
    }
  }
}
