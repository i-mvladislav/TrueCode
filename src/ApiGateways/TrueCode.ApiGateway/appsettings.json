{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "YarpProxy": {
    "Routes": {
      "finance-service-api": {
        "ClusterId": "finance-api",
        "Match": {
          "Path": "/finance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "user-service-api": {
        "ClusterId": "user-api",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "finance-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:3001/"
          }
        }
      },
      "user-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:2001/"
          }
        }
      }
    }
  }
}
